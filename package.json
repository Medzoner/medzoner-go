    "yarn": "^1.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.6",
    "@types/node": "^14.0.13",
    "@types/uuid": "^8.0.0",
    "@vue/cli-plugin-babel": "^4.4.4",
    "@vue/cli-service": "^4.4.4",
    "express": "^4.17.1",
    "grpc": "^1.24.3",
    "nodemon": "^2.0.4",
    "ts-node": "^8.10.2",
    "typescript": "^3.9.5",
    "uuid": "^8.1.0",
    "vue": "^2.6.11"
  }
}
